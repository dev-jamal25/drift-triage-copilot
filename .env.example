# ===== Postgres =====
POSTGRES_USER=drift_user
POSTGRES_PASSWORD=change_me_locally
POSTGRES_DB=drift_triage
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Composed URL — services use this
DATABASE_URL=postgresql+asyncpg://drift_user:change_me_locally@postgres:5432/drift_triage

# ===== Redis =====
REDIS_URL=redis://redis:6379/0

# ===== MLflow =====
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_BACKEND_STORE_URI=postgresql://drift_user:change_me_locally@postgres:5432/drift_triage
MLFLOW_DEFAULT_ARTIFACT_ROOT=/mlflow/artifacts

# ===== Platform service =====
PLATFORM_MODEL_NAME=bank-marketing-classifier
PLATFORM_MODEL_ALIAS=staging
PLATFORM_LOAD_MODEL_ON_STARTUP=true
PLATFORM_LOG_LEVEL=INFO

# ===== LLM =====
# Pick one provider — if you change, also update agent/app/core/config.py
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
AGENT_USE_LLM=true
LLM_TRIAGE_MODEL=claude-haiku-4-5-20251001
LLM_ACTION_MODEL=claude-sonnet-4-6
LLM_COMMS_MODEL=claude-haiku-4-5-20251001
AGENT_LLM_TIMEOUT_SECONDS=20

# ===== Service URLs (compose internal hostnames) =====
MODEL_SERVICE_URL=http://model-service:8000
AGENT_URL=http://agent:8001
AGENT_WEBHOOK_URL=http://agent:8001/webhooks/drift

# ===== Worker =====
WORKER_MAX_RETRIES=3
WORKER_BACKOFF_BASE_SECONDS=2
WORKER_HTTP_TIMEOUT_SECONDS=10
WORKER_RETRY_MAX_BACKOFF_SECONDS=60

# ===== Misc =====
LOG_LEVEL=INFO

# ===== LangSmith Tracing (for LLM observability) =====
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=drift-triage-copilot
